    {
      "id": "ins_text",
      "type": "text",
      "x": 92,
      "y": 492,
      "width": 885,
      "height": 56,
      "text": "Key insight: A software system with identical properties produces identical output. An ML system\ncannot guarantee this. An LLM system adds further uncontrollable variables: an external model you do\nnot own, plus non-deterministic output, retrieved context, cost, and even evaluation.",
      "fontSize": 14,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#5c5638",
      "backgroundColor": "transparent",
